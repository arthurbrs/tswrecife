{
  "name": "tswrecife",
  "main": "worker.js",
  "compatibility_date": "2025-02-04",
  "assets": {
    "directory": "./",
    "binding": "ASSETS"
  },
  "r2_buckets": [
    {
      "binding": "SPONSORS_BUCKET",
      "bucket_name": "startup-weekend"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "PLACAR_ROOM",
        "class_name": "PlacarRealtimeRoom"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "PlacarRealtimeRoom"
      ]
    }
  ]
}
