{
  "name": "tswrecife",
  "main": "worker.js",
  "compatibility_date": "2025-02-04",
  "assets": {
    "directory": "./",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": false,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": false,
      "persist": true,
      "head_sampling_rate": 1
    }
  },
  "secrets": {
    "required": [
      "ADMIN_PASSWORD",
      "SESSION_SECRET",
      "PUSHER_APP_ID",
      "PUSHER_KEY",
      "PUSHER_SECRET",
      "PUSHER_CLUSTER"
    ]
  },
  "kv_namespaces": [
    {
      "binding": "PLACAR_KV",
      "id": "fe4d874300d148d6a359364b8ad6ebdf"
    }
  ]
}
